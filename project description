Exposure Table

sql
CREATE TABLE Exposure (
    exposureId INTEGER PRIMARY KEY AUTOINCREMENT,
    userId INTEGER,
    startTime TIMESTAMP NOT NULL,
    endTime TIMESTAMP,
    avgLightLux REAL,
    uvIndex REAL,
    latitude REAL,
    longitude REAL,
    locationName TEXT,
    burned BOOLEAN DEFAULT false,
    notes TEXT,
    FOREIGN KEY(userId) REFERENCES User(userId)
);
